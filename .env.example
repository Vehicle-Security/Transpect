# Transpect optional local configuration.
#
# Level 0 frozen showcase replay does not require this file.
# Copy this file to .env when you want to run live Agent traces, enable the
# Agent Defense LLM gray-zone judge, or run CodeTracer diagnosis.
#
# Never commit .env. Only this example file is safe to commit.

# OpenAI-compatible LLM endpoint used by:
# - app/security/model_judge.py for Agent Defense gray-zone decisions
# - task repo runners through MODEL_* normalization
# - CodeTracer diagnosis unless CODETRACER_* overrides are set below
BASE_URL=https://api.openai.com/v1
API_KEY=
MODEL_ID=gpt-4o-mini

# Optional explicit model variables used by task repo adapters.
# If left empty, scripts/common/task_repo_common.py maps BASE_URL/API_KEY/MODEL_ID
# to MODEL_BASE_URL/MODEL_API_KEY/MODEL_NAME.
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=

# Optional CodeTracer location and backend overrides.
# CodeTracer is not required for frozen showcase replay. If missing during a
# live run, Transpect writes diagnosis status "unavailable" and continues.
CODETRACER_ROOT=
CODETRACER_SRC=
CODETRACER_API_BASE=
CODETRACER_API_KEY=
CODETRACER_MODEL=

# Optional R-Judge dataset root. Only needed for --repo rjudge.
R_JUDGE_ROOT=

# Optional OpenClaw binary override for live Agent runs.
OPENCLAW_BIN=

# Optional Agent Defense policy override.
TRANSPECT_AGENT_DEFENSE_POLICY=
