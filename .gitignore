# Python
__pycache__/
*.pyc
.DS_Store
.venv*/
.conda*/

# Local OpenClaw runtime state
.openclaw/

# Environment files
.env
.env.*
!.env.example

# Runtime outputs
live/**
!live/.gitkeep
!live/otel/
!live/otel/.gitkeep
captures/**
!captures/.gitkeep
bin/**
!bin/.gitkeep
.playwright-mcp/
tmp-*.log
tmp-*.jsonl

# Local config snapshots and rendered files
config/applied/**
config/*.local.yaml

# Optional vendor dependencies
vendor/external/openclaw-observability-plugin/node_modules/

# Keep only repository screenshots
docs/images/*.png
docs/images/console-pages/
