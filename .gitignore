# Python
__pycache__/
*.pyc
.DS_Store
.venv*/
.conda*/

# Local OpenClaw runtime state
.openclaw/

# Environment files
.env
.env.*
!.env.example

# Runtime outputs
monitor/live/**
!monitor/live/.gitkeep
!monitor/live/otel/
!monitor/live/otel/.gitkeep
monitor/captures/**
!monitor/captures/.gitkeep
monitor/bin/**
!monitor/bin/.gitkeep
.playwright-mcp/
tmp-*.log
tmp-*.jsonl

# Local config snapshots and rendered files
config/applied/**
config/*.local.yaml

# Optional vendor dependencies
monitor/vendor/external/openclaw-observability-plugin/node_modules/

# Keep only repository screenshots
docs/images/*.png
docs/images/console-pages/
!docs/images/runtime-traces.png
!docs/images/runtime-timeline.png
!docs/images/runtime-timeline-detail.png
!docs/images/runtime-timeline-evidence.png
!docs/images/console-overview-dashboard.png
!docs/images/console-showcase-gallery.png
!docs/images/console-staged-attack-report.png
!docs/images/console-artifact-viewer.png
