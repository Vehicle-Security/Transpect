# Python
__pycache__/
*.pyc
.venv*/
.conda*/

# Local OpenClaw runtime state
.openclaw/

# Environment files
.env
.env.*

# Runtime outputs
live/**
!live/.gitkeep
!live/otel/
!live/otel/.gitkeep
captures/**
!captures/.gitkeep
bin/**
!bin/.gitkeep
tmp-*.log
tmp-*.jsonl

# Local config snapshots and rendered files
config/applied/**
config/*.local.yaml

# Optional vendor dependencies
vendor/external/openclaw-observability-plugin/node_modules/

# Keep only repository screenshots
docs/images/*.png
!docs/images/runtime-traces.png
!docs/images/runtime-timeline.png
!docs/images/runtime-timeline-detail.png
!docs/images/runtime-timeline-evidence.png
